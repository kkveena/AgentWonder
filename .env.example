# AgentWonder environment configuration
# Copy this file to .env and fill in your values.

# Google Gemini API key (required for LLM execution)
GOOGLE_API_KEY=your-gemini-api-key-here

# Logging (optional, defaults to INFO)
# AGENTWONDER_LOG_LEVEL=DEBUG
# AGENTWONDER_LOG_JSON=true

# Persistence (optional, defaults to memory)
# AGENTWONDER_PERSISTENCE=file
# AGENTWONDER_DATA_DIR=data
